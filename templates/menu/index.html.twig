{% extends 'base.html.twig' %}

{% block head_title %}
    Menu index
{% endblock %}

{% block title %}
    Menu index
{% endblock %}

{% block content %}
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Url</th>
                <th>Label</th>
                <th>Weight</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
            {% for menu in menus %}
                <tr>
                    <td>{{ menu.id }}</td>
                    <td>{{ menu.url }}</td>
                    <td>{{ menu.label }}</td>
                    <td>{{ menu.weight }}</td>
                    <td>
                        <a href="{{ path('app_menu_show', {'id': menu.id}) }}">show</a>
                        <a href="{{ path('app_menu_edit', {'id': menu.id}) }}">edit</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">no records found</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_menu_new') }}">Create new</a>
{% endblock %}
